generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  password     String
  name         String
  lastName     String?        // ← добавлено: фамилия клиента
  internalTag  String?        // ← псевдоним, для тренера
  age          Int
  role         String         @default("USER")
  createdAt    DateTime?      @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?      @default(now()) @updatedAt @db.Timestamp(6)
  telegramId   String?        @unique

  payments     PaymentBlock[]
  trainings    Training[]
}

model Training {
  id           String   @id @default(cuid())
  date         DateTime @db.Timestamp(6)
  hour         Int
  userId       String
  status       Status   @default(PENDING)
  attended     Boolean? // может быть null
  wasCounted   Boolean  @default(false) // 🔒 защита от повторного списания
  isSinglePaid Boolean  @default(false) // ✅ разовая оплата
  createdAt    DateTime? @default(now()) @db.Timestamp(6)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model PaymentBlock {
  id               String   @id @default(cuid())
  userId           String
  paidTrainings    Int
  used             Int      @default(0)
  pricePerTraining Int
  paidAt           DateTime @default(now()) @db.Timestamp(6)
  active           Boolean  @default(true)

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

enum Status {
  PENDING
  CONFIRMED
  DECLINED
}
