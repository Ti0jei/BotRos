generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  password            String
  name                String
  lastName            String?        // фамилия клиента
  internalTag         String?        // псевдоним, для тренера
  age                 Int
  role                String         @default("USER")
  telegramId          String?        @unique
  createdAt           DateTime?      @default(now()) @db.Timestamp(6)
  updatedAt           DateTime?      @default(now()) @updatedAt @db.Timestamp(6)

  emailVerified       Boolean        @default(false)
  emailToken          String?        @unique
  emailTokenExpires   DateTime?

  // 🔐 поля для сброса пароля
  resetToken          String?        @unique
  resetTokenExpires   DateTime?

  // 🔕 выключение оповещений (кроме подтверждения тренировок)
  notificationsMuted  Boolean        @default(false)

  payments            PaymentBlock[]
  trainings           Training[]
  nutrition           Nutrition[]
}

model Training {
  id           String   @id @default(cuid())
  date         DateTime @db.Timestamp(6)
  hour         Int
  userId       String
  status       Status   @default(PENDING)
  attended     Boolean?
  wasCounted   Boolean  @default(false)
  isSinglePaid Boolean  @default(false)
  createdAt    DateTime? @default(now()) @db.Timestamp(6)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentBlock {
  id               String   @id @default(cuid())
  userId           String
  paidTrainings    Int
  used             Int      @default(0)
  pricePerTraining Int
  paidAt           DateTime @default(now()) @db.Timestamp(6)
  active           Boolean  @default(true)

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Nutrition {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  calories  Int
  protein   Int
  fat       Int
  carbs     Int

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

enum Status {
  PENDING
  CONFIRMED
  DECLINED
}
