generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  password   String
  name       String
  age        Int
  telegramId String? // ← должно быть
  role       Role       @default(USER)
  trainings  Training[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Training {
  id        String   @id @default(cuid())
  date      DateTime
  hour      Int
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  status    Status   @default(PENDING)
  attended  Boolean? // ← Новое поле
  createdAt DateTime @default(now())
}

enum Status {
  PENDING
  CONFIRMED
  DECLINED
}
